# ============================================================
# VENTRA — Environment Variables
# ============================================================
# SECRET ROTATION POLICY:
#   - JWT_SECRET: rotate every 90 days (invalidates all sessions)
#   - DATABASE password: rotate every 180 days
#   - ANTHROPIC_API_KEY: rotate if compromised
#   - REDIS password: rotate with DATABASE password
#   - All secrets: use 32+ char random strings (openssl rand -hex 32)
# ============================================================

# Database
DATABASE_URL="postgresql://uzum:uzum_pass@localhost:5432/uzum_trend_finder"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# Anthropic (Claude AI)
ANTHROPIC_API_KEY="sk-ant-..."

# SerpAPI (Sourcing)
SERPAPI_API_KEY=""

# AliExpress Affiliate (Sourcing)
ALIEXPRESS_APP_KEY=""
ALIEXPRESS_APP_SECRET=""

# Telegram Bot
TELEGRAM_BOT_TOKEN=""
WEB_URL="https://ventra.uz"

# Proxy (residential, muhim!)
PROXY_URL=""

# Bright Data Scraping Browser (CDP) — apps/worker/src/browser-pool.ts
# Bright Data dashboard: Scraping Browser → Access parameters → Username + Password
BRIGHT_DATA_USERNAME=""
BRIGHT_DATA_PASSWORD=""

# Cloudflare (CDN + cache purge)
CLOUDFLARE_API_KEY=""
CLOUDFLARE_EMAIL=""
CLOUDFLARE_ZONE_ID=""
CLOUDFLARE_ACCOUNT_ID=""

# App
PORT=3000
NODE_ENV="development"

# Seed (production da MAJBURIY, dev da fallback ishlatiladi)
SEED_ADMIN_EMAIL="admin@ventra.uz"
SEED_ADMIN_PASSWORD=""
SEED_DEMO_EMAIL="demo@ventra.uz"
SEED_DEMO_PASSWORD=""

# Super Admin Account ID (stats dan chiqarib tashlash uchun)
SUPER_ADMIN_ACCOUNT_ID="aaaaaaaa-0000-0000-0000-000000000001"

# Worker: Playwright wait times (ms) — sekin muhit uchun oshirish mumkin
BANGGOOD_LOAD_WAIT_MS=8000
BANGGOOD_SCROLL_WAIT_MS=2000
SHOPEE_LOAD_WAIT_MS=6000
SHOPEE_SCROLL_WAIT_MS=2000

# Worker: Customs & VAT rates (default: Uzbekistan rates)
CUSTOMS_DUTY_RATE=0.10
VAT_RATE=0.12

# Worker: Discovery source (false = Playwright only, default: GraphQL first)
USE_GRAPHQL_DISCOVERY=true

# Worker: Health check port
WORKER_HEALTH_PORT=3001
# Worker: Internal URL for API→Worker communication (Railway: http://worker.railway.internal:3001)
# WORKER_URL=http://worker.railway.internal:3001
