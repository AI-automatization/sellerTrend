#!/usr/bin/env sh

# === ZONA ENFORCEMENT ===
# Bekzod: PM — faqat docs/, CLAUDE.md, .husky/ — apps/ va packages/ TAQIQLANGAN
# Ziyoda: apps/api, apps/web, apps/worker — landing/desktop/bot/extension TAQIQLANGAN
# Sardor: FULL zona — hech qanday cheklov yo'q

COMMITTER_NAME=$(git config user.name)
COMMITTER_EMAIL=$(git config user.email)

# === Identifikatsiya ===

IS_BEKZOD=false
case "$COMMITTER_NAME" in
  *[Bb]ekzod*) IS_BEKZOD=true ;;
esac
case "$COMMITTER_EMAIL" in
  *bekzod*) IS_BEKZOD=true ;;
esac

IS_ZIYODA=false
case "$COMMITTER_NAME" in
  *[Zz]iyoda*) IS_ZIYODA=true ;;
esac
case "$COMMITTER_EMAIL" in
  *ziyoda*) IS_ZIYODA=true ;;
esac

IS_SARDOR=false
case "$COMMITTER_NAME" in
  *[Ss]ardor*) IS_SARDOR=true ;;
esac
case "$COMMITTER_EMAIL" in
  *sardor*) IS_SARDOR=true ;;
esac

# === Sardor — FULL zona, cheklov yo'q ===

# === Bekzod — PM, faqat docs/ ruxsat, apps/ va packages/ TAQIQLANGAN ===
if [ "$IS_BEKZOD" = true ]; then
  BLOCKED_FILES=$(git diff --cached --name-only | grep -E "^(apps/|packages/)" || true)

  if [ -n "$BLOCKED_FILES" ]; then
    echo ""
    echo "══════════════════════════════════════════════════════════════"
    echo "  ❌ COMMIT BLOKLANDI — ZONA BUZILISHI"
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    echo "  Bekzod, siz PM sifatida kod fayllariga commit qilolmaysiz:"
    echo ""
    echo "$BLOCKED_FILES" | while read -r file; do
      echo "    ❌ $file"
    done
    echo ""
    echo "  SIZNING ZONA (PM):"
    echo "    ✅ docs/            — Task boshqaruvi, dokumentatsiya"
    echo "    ✅ CLAUDE.md        — Loyiha konfiguratsiyasi"
    echo "    ✅ .husky/          — Git hooks"
    echo ""
    echo "  TAQIQLANGAN:"
    echo "    ❌ apps/*           — Barcha applar (Sardor/Ziyoda)"
    echo "    ❌ packages/*       — Shared types/utils (Sardor/Ziyoda)"
    echo ""
    echo "  Kod o'zgarishi kerak bo'lsa — Sardor yoki Ziyodaga task yozing."
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    exit 1
  fi
fi

# === Ziyoda — landing/desktop/bot/extension TAQIQLANGAN ===
if [ "$IS_ZIYODA" = true ]; then
  BLOCKED_FILES=$(git diff --cached --name-only | grep -E "^(apps/landing/|apps/desktop/|apps/bot/|apps/extension/)" || true)

  if [ -n "$BLOCKED_FILES" ]; then
    echo ""
    echo "══════════════════════════════════════════════════════════════"
    echo "  ❌ COMMIT BLOKLANDI — ZONA BUZILISHI"
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    echo "  Ziyoda, siz quyidagi fayllarga commit qilolmaysiz:"
    echo ""
    echo "$BLOCKED_FILES" | while read -r file; do
      echo "    ❌ $file"
    done
    echo ""
    echo "  SIZNING ZONA:"
    echo "    ✅ apps/api/        — Backend API"
    echo "    ✅ apps/web/        — Frontend Web dashboard"
    echo "    ✅ apps/worker/     — BullMQ Worker"
    echo "    ✅ packages/        — Shared (lock bilan)"
    echo "    ✅ docs/            — Dokumentatsiya"
    echo ""
    echo "  TAQIQLANGAN ZONA (Sardor mas'ul):"
    echo "    ❌ apps/landing/    — Landing page"
    echo "    ❌ apps/desktop/    — Desktop app"
    echo "    ❌ apps/bot/        — Telegram bot"
    echo "    ❌ apps/extension/  — Chrome Extension"
    echo ""
    echo "  Agar bu o'zgarish zarur bo'lsa — Sardor bilan gaplashing."
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    exit 1
  fi
fi

# Lint-staged (barcha uchun)
npx lint-staged
