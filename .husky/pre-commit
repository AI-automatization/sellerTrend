#!/usr/bin/env sh

# === ZONA ENFORCEMENT — Zone violations qilolmaydi ===
# Bekzod: apps/api, apps/web, apps/worker
# Sardor: apps/landing, apps/desktop, apps/bot, apps/extension

COMMITTER_NAME=$(git config user.name)
COMMITTER_EMAIL=$(git config user.email)

# Sardor identifikatsiya (ism yoki email bo'yicha)
IS_SARDOR=false
case "$COMMITTER_NAME" in
  *[Ss]ardor*) IS_SARDOR=true ;;
esac
case "$COMMITTER_EMAIL" in
  *sardor*) IS_SARDOR=true ;;
esac

# Bekzod identifikatsiya
IS_BEKZOD=false
case "$COMMITTER_NAME" in
  *[Bb]ekzod*) IS_BEKZOD=true ;;
esac
case "$COMMITTER_EMAIL" in
  *bekzod*) IS_BEKZOD=true ;;
esac

if [ "$IS_SARDOR" = true ]; then
  # Sardor uchun taqiqlangan zona'lar (Bekzod)
  BLOCKED_FILES=$(git diff --cached --name-only | grep -E "^(apps/api/|apps/web/|apps/worker/)" || true)

  if [ -n "$BLOCKED_FILES" ]; then
    echo ""
    echo "══════════════════════════════════════════════════════════════"
    echo "  ❌ COMMIT BLOKLANDI — ZONA BUZILISHI"
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    echo "  Sardor, siz quyidagi fayllarga commit qilolmaysiz:"
    echo ""
    echo "$BLOCKED_FILES" | while read -r file; do
      echo "    ❌ $file"
    done
    echo ""
    echo "  SIZNING ZONA:"
    echo "    ✅ apps/landing/    — Landing page"
    echo "    ✅ apps/desktop/    — Desktop app"
    echo "    ✅ apps/bot/        — Telegram bot"
    echo "    ✅ apps/extension/  — Chrome Extension"
    echo "    ✅ packages/        — Shared (lock bilan)"
    echo "    ✅ docs/            — Dokumentatsiya"
    echo ""
    echo "  TAQIQLANGAN ZONA (Bekzod mas'ul):"
    echo "    ❌ apps/api/        — Backend API"
    echo "    ❌ apps/web/        — Frontend Web dashboard"
    echo "    ❌ apps/worker/     — BullMQ Worker"
    echo ""
    echo "  Agar bu o'zgarish zarur bo'lsa — Bekzod bilan gaplashing."
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    exit 1
  fi
fi

if [ "$IS_BEKZOD" = true ]; then
  # Bekzod uchun taqiqlangan zona'lar (Sardor)
  BLOCKED_FILES=$(git diff --cached --name-only | grep -E "^(apps/landing/|apps/desktop/|apps/bot/|apps/extension/)" || true)

  if [ -n "$BLOCKED_FILES" ]; then
    echo ""
    echo "══════════════════════════════════════════════════════════════"
    echo "  ❌ COMMIT BLOKLANDI — ZONA BUZILISHI"
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    echo "  Bekzod, siz quyidagi fayllarga commit qilolmaysiz:"
    echo ""
    echo "$BLOCKED_FILES" | while read -r file; do
      echo "    ❌ $file"
    done
    echo ""
    echo "  SIZNING ZONA:"
    echo "    ✅ apps/api/        — Backend API"
    echo "    ✅ apps/web/        — Frontend Web dashboard"
    echo "    ✅ apps/worker/     — BullMQ Worker"
    echo "    ✅ packages/        — Shared (lock bilan)"
    echo "    ✅ docs/            — Dokumentatsiya"
    echo ""
    echo "  TAQIQLANGAN ZONA (Sardor mas'ul):"
    echo "    ❌ apps/landing/    — Landing page"
    echo "    ❌ apps/desktop/    — Desktop app"
    echo "    ❌ apps/bot/        — Telegram bot"
    echo "    ❌ apps/extension/  — Chrome Extension"
    echo ""
    echo "  Agar bu o'zgarish zarur bo'lsa — Sardor bilan gaplashing."
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    exit 1
  fi
fi

# Lint-staged (barcha uchun)
npx lint-staged
